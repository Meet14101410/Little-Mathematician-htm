let a = 2, b = 3;

function check() {
  let ans = document.getElementById("answer").value;
  let result = document.getElementById("result");

  if (ans == a + b) {
    result.textContent = "🎉 Correct!";
    result.style.color = "green";
  } else {
    result.textContent = "❌ Try Again!";
    result.style.color = "red";
  }
}
